# 서버 전용 (UI에서 Key 입력 없음)
OPENAI_API_KEY=
# gpt-5.2, gpt-5, o3-pro, gpt-4.1, gpt-4o 등 API에서 허용된 모델 ID
OPENAI_MODEL=gpt-4o
# sk-proj- Key 발급 시 같은 프로젝트의 ID (필수인 경우 많음)
# Platform → 프로젝트 → Settings → Project ID
OPENAI_PROJECT_ID=
# 설정 검증: node scripts/configure-openai.mjs proj_xxx
# 여러 조직 소속 시
OPENAI_ORG_ID=
# (레거시) Key가 .env에 있으면 자동 사용. mock만 끌 때 false
ALLOW_SERVER_DEFAULT_OPENAI_KEY=true

# Vercel Pro 배포 시 발명 분석·전체 작성용 (ms). Hobby(10초)만으로는 분석이 끊깁니다.
ANALYZE_TIMEOUT_MS=240000

# 개발 환경에서 API Key 없이 mock 분석 허용 (기본: 허용, false로 끄기)
ALLOW_MOCK_WITHOUT_OPENAI_KEY=

# 도면 생성 — Gemini API (Nano Banana 2 / gemini-3.1-flash-image). 서버 전용, UI에 노출하지 않음
# Google AI Studio → Get API key (유료 결제 연결 Key 권장)
GEMINI_API_KEY=
# 미설정 시 gemini-3.1-flash-image. 미지원이면 gemini-2.5-flash-image 등으로 변경
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Key 없을 때 「도면 생성」이 여는 URL (수동 붙여넣기)
NEXT_PUBLIC_NANO_BANANA_URL=
