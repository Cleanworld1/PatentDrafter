{
  "name": "patent-drafter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev",
    "dev:restart": "node scripts/dev-restart.mjs",
    "verify:dev": "node scripts/verify-localhost.mjs",
    "diagnose": "node scripts/diagnose-app.mjs",
    "dev:fix": "node scripts/dev-restart.mjs && node scripts/verify-localhost.mjs",
    "build": "node scripts/verify-dev-not-running.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:openai-env": "node scripts/test-openai-env.mjs"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "mammoth": "^1.12.0",
    "next": "^15.3.3",
    "@napi-rs/canvas": "^0.1.80",
    "pdf-parse": "^2.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.1"
  }
}
